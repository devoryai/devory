{
  "name": "@devory/cli",
  "version": "0.4.9",
  "description": "Devory CLI — formal command interface for Devory",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devoryai/devory.git"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "src/index.ts",
    "README.md"
  ],
  "bin": {
    "devory": "dist/bin.js"
  },
  "scripts": {
    "build": "npm run build:bin && npm run build:lib",
    "build:bin": "esbuild src/bin.ts --bundle --outfile=dist/bin.js --platform=node --format=cjs --external:readline/promises --banner:js='#!/usr/bin/env node'",
    "build:lib": "esbuild src/index.ts --bundle --outfile=dist/index.js --platform=node --format=cjs --external:readline/promises",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@devory/github": "0.4.9",
    "@supabase/supabase-js": "^2.50.5",
    "glob": "^11.0.3"
  },
  "devDependencies": {
    "@devory/core": "0.4.9",
    "esbuild": "^0.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
