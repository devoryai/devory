{
  "name": "@devory/core",
  "version": "0.1.1",
  "description": "Shared types, parsing utilities, and path configuration for AI Dev Factory",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": "./dist/index.js"
