{
  "name": "devory-vscode",
  "displayName": "Devory.AI",
  "description": "Repo-aware task, run, doctrine, and review workflow for Devory in VS Code",
  "version": "0.4.9",
  "publisher": "DevoryAI",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:devoryTaskExplorer",
    "onView:devoryFactoryExplorer",
    "onView:devoryShowWork"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devory.taskList",
        "title": "Devory: List Tasks"
      },
      {
        "command": "devory.taskCreate",
        "title": "Devory: Create Task",
        "icon": "$(add)"
      },
      {
        "command": "devory.generateTasksFromIdea",
        "title": "Devory: Generate Tasks from Idea",
        "icon": "$(sparkle)"
      },
      {
        "command": "devory.taskMove",
        "title": "Devory: Move Task"
      },
      {
        "command": "devory.taskPromote",
        "title": "Devory: Promote Task",
        "icon": "$(arrow-up)"
      },
      {
        "command": "devory.reviewQueue",
        "title": "Devory: Open Review Queue",
        "icon": "$(checklist)"
      },
      {
        "command": "devory.enrichTask",
        "title": "Devory: Enrich Task",
        "icon": "$(sparkle)"
      },
      {
        "command": "devory.addAcceptanceCriteria",
        "title": "Devory: Add Acceptance Criteria"
      },
      {
        "command": "devory.addVerification",
        "title": "Devory: Add Verification Steps"
      },
      {
        "command": "devory.addDependencies",
        "title": "Devory: Add Dependencies"
      },
      {
        "command": "devory.addFilesAffected",
        "title": "Devory: Add Files Likely Affected"
      },
      {
        "command": "devory.taskApprove",
        "title": "Devory: Approve Review Task"
      },
      {
        "command": "devory.taskSendBack",
        "title": "Devory: Send Review Task Back"
      },
      {
        "command": "devory.taskBlock",
        "title": "Devory: Block Review Task"
      },
      {
        "command": "devory.taskRequeue",
        "title": "Devory: Requeue Blocked Task"
      },
      {
        "command": "devory.runStart",
        "title": "Devory: Start Factory Run",
        "icon": "$(play)"
      },
      {
        "command": "devory.runResume",
        "title": "Devory: Resume Factory Run"
      },
      {
        "command": "devory.runPause",
        "title": "Devory: Pause or Resume Factory Run",
        "icon": "$(debug-pause)"
      },
      {
        "command": "devory.runStop",
        "title": "Devory: Stop Factory Run",
        "icon": "$(primitive-square)"
      },
      {
        "command": "devory.runInspect",
        "title": "Devory: Inspect Recent Runs",
        "icon": "$(history)"
      },
      {
        "command": "devory.showRoutingOutcomeSummary",
        "title": "Devory: Show Routing Outcome Summary",
        "icon": "$(graph-line)"
      },
      {
        "command": "devory.artifactInspect",
        "title": "Devory: Inspect Artifacts"
      },
      {
        "command": "devory.initWorkspace",
        "title": "Devory: Initialize Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "devory.factoryDoctor",
        "title": "Devory: Governance Doctor",
        "icon": "$(tools)"
      },
      {
        "command": "devory.cloudConnect",
        "title": "Devory: Connect Cloud Account",
        "icon": "$(cloud)"
      },
      {
        "command": "devory.openGettingStarted",
        "title": "Devory: Open Getting Started",
        "icon": "$(book)"
      },
      {
        "command": "devory.doctrineCreate",
        "title": "Devory: Create Doctrine File",
        "icon": "$(add)"
      },
      {
        "command": "devory.skillCreate",
        "title": "Devory: Create Skill",
        "icon": "$(add)"
      },
      {
        "command": "devory.agentCreate",
        "title": "Devory: Create Agent",
        "icon": "$(add)"
      },
      {
        "command": "devory.doctrineArchive",
        "title": "Devory: Archive Doctrine File"
      },
      {
        "command": "devory.skillArchive",
        "title": "Devory: Archive Skill"
      },
      {
        "command": "devory.taskArchive",
        "title": "Devory: Archive Task"
      },
      {
        "command": "devory.showGovernanceStatus",
        "title": "Devory: Show Governance Status",
        "icon": "$(info)"
      },
      {
        "command": "devory.refresh",
        "title": "Devory: Refresh Devory Views",
        "icon": "$(refresh)"
      },
      {
        "command": "devory.showStoredDataLocations",
        "title": "Devory: Show Stored Data Locations"
      },
      {
        "command": "devory.sweepWorkshop",
        "title": "Devory: Sweep the Workshop"
      },
      {
        "command": "devory.focusTaskAssistant",
        "title": "Devory: Draft Task",
        "icon": "$(edit)"
      },
      {
        "command": "devory.showWork",
        "title": "Devory: Show Work",
        "icon": "$(pulse)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "devoryTaskExplorer",
          "name": "Devory: Tasks"
        },
        {
          "id": "devoryShowWork",
          "name": "Devory: Show Work",
          "type": "webview"
        },
        {
          "id": "devoryFactoryExplorer",
          "name": "Devory: Governance"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "devory.initWorkspace",
          "when": "view == devoryTaskExplorer && !devory.workspaceInitialized",
          "group": "navigation@0"
        },
        {
          "command": "devory.refresh",
          "when": "view == devoryTaskExplorer",
          "group": "navigation"
        },
        {
          "command": "devory.refresh",
          "when": "view == devoryShowWork",
          "group": "navigation"
        },
        {
          "command": "devory.runInspect",
          "when": "view == devoryShowWork",
          "group": "navigation@1"
        },
        {
          "command": "devory.refresh",
          "when": "view == devoryFactoryExplorer",
          "group": "navigation"
        },
        {
          "command": "devory.factoryDoctor",
          "when": "view == devoryFactoryExplorer",
          "group": "navigation@1"
        },
        {
          "command": "devory.cloudConnect",
          "when": "view == devoryFactoryExplorer",
          "group": "navigation@0.5"
        },
        {
          "command": "devory.generateTasksFromIdea",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized",
          "group": "navigation@1"
        },
        {
          "command": "devory.taskCreate",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized",
          "group": "navigation@1.5"
        },
        {
          "command": "devory.taskPromote",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized",
          "group": "navigation@2"
        },
        {
          "command": "devory.reviewQueue",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized",
          "group": "navigation@3"
        },
        {
          "command": "devory.runStart",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized && !devory.runActive",
          "group": "navigation@4"
        },
        {
          "command": "devory.runStart",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized && devory.runPaused",
          "group": "navigation@4"
        },
        {
          "command": "devory.runPause",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized && devory.runActive",
          "group": "navigation@5"
        },
        {
          "command": "devory.runStop",
          "when": "view == devoryTaskExplorer && devory.workspaceInitialized && devory.runActive",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "devory.taskPromote",
          "when": "view == devoryTaskExplorer && viewItem == task.backlog",
          "group": "inline"
        },
        {
          "command": "devory.taskPromote",
          "when": "view == devoryTaskExplorer && viewItem == task.ready",
          "group": "inline"
        },
        {
          "command": "devory.taskPromote",
          "when": "view == devoryTaskExplorer && viewItem == task.doing",
          "group": "inline"
        },
        {
          "command": "devory.taskApprove",
          "when": "view == devoryTaskExplorer && viewItem == task.review",
          "group": "inline"
        },
        {
          "command": "devory.taskSendBack",
          "when": "view == devoryTaskExplorer && viewItem == task.review",
          "group": "navigation@1"
        },
        {
          "command": "devory.taskBlock",
          "when": "view == devoryTaskExplorer && viewItem == task.review",
          "group": "navigation@2"
        },
        {
          "command": "devory.taskRequeue",
          "when": "view == devoryTaskExplorer && viewItem == task.blocked",
          "group": "inline"
        },
        {
          "command": "devory.taskRequeue",
          "when": "view == devoryTaskExplorer && viewItem == task.archived",
          "group": "inline"
        },
        {
          "command": "devory.taskArchive",
          "when": "view == devoryTaskExplorer && viewItem =~ /^task\\.(backlog|ready|doing|review|blocked)$/",
          "group": "navigation@4"
        },
        {
          "command": "devory.reviewQueue",
          "when": "view == devoryTaskExplorer && viewItem == task.review",
          "group": "navigation@3"
        },
        {
          "command": "devory.enrichTask",
          "when": "view == devoryTaskExplorer && viewItem =~ /^task\\.(backlog|ready)$/",
          "group": "navigation@5"
        },
        {
          "command": "devory.doctrineCreate",
          "when": "view == devoryFactoryExplorer && viewItem == devoryGroup.doctrine",
          "group": "inline"
        },
        {
          "command": "devory.skillCreate",
          "when": "view == devoryFactoryExplorer && viewItem == devoryGroup.skills",
          "group": "inline"
        },
        {
          "command": "devory.agentCreate",
          "when": "view == devoryFactoryExplorer && viewItem == devoryGroup.agents",
          "group": "inline"
        },
        {
          "command": "devory.doctrineArchive",
          "when": "view == devoryFactoryExplorer && viewItem == devoryDoctrineFile",
          "group": "navigation@1"
        },
        {
          "command": "devory.skillArchive",
          "when": "view == devoryFactoryExplorer && viewItem == devorySkill",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "command": "devory.taskPromote",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/(backlog|ready|doing)\\//",
          "group": "navigation@10"
        },
        {
          "command": "devory.taskApprove",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/review\\//",
          "group": "navigation@11"
        },
        {
          "command": "devory.taskSendBack",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/review\\//",
          "group": "navigation@12"
        },
        {
          "command": "devory.taskBlock",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/review\\//",
          "group": "navigation@13"
        },
        {
          "command": "devory.taskRequeue",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/(blocked|archived)\\//",
          "group": "navigation@14"
        },
        {
          "command": "devory.taskArchive",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/(backlog|ready|doing|review|blocked)\\//",
          "group": "navigation@15"
        },
        {
          "command": "devory.reviewQueue",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/review\\//",
          "group": "navigation@16"
        },
        {
          "command": "devory.enrichTask",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\/(backlog|ready)\\//",
          "group": "navigation@17"
        },
        {
          "command": "devory.showWork",
          "when": "resourceExtname == .md && resourcePath =~ /\\/tasks\\//",
          "group": "navigation@18"
        }
      ]
    },
    "configuration": {
      "title": "Devory",
      "properties": {
        "devory.factoryRoot": {
          "type": "string",
          "default": "",
          "description": "Absolute path to your Devory workspace root. Leave blank to auto-detect from workspace."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "devory.gettingStarted",
        "title": "Get started with Devory",
        "description": "Set up your AI dev factory in four steps.",
        "steps": [
          {
            "id": "devory.step.setRoot",
            "title": "Point Devory at your workspace",
            "description": "Set ``devory.factoryRoot`` to the absolute path of your project root, or leave it blank to auto-detect from the open workspace.\n\n[Open Settings](command:workbench.action.openSettings?%5B%22devory.factoryRoot%22%5D)",
            "media": {
              "image": "icon.png",
              "altText": "Devory"
            }
          },
          {
            "id": "devory.step.init",
            "title": "Initialize your workspace",
            "description": "Scaffold task directories, starter doctrine, and skill files with one command.\n\n[Initialize Workspace](command:devory.initWorkspace)",
            "media": {
              "image": "icon.png",
              "altText": "Devory"
            },
            "completionEvents": [
              "onContext:devory.workspaceInitialized"
            ]
          },
          {
            "id": "devory.step.createTask",
            "title": "Create Task",
            "description": "Describe a unit of work for the AI agent. It lands in ``tasks/backlog/`` ready to be promoted.\n\n[Create Task](command:devory.taskCreate)",
            "media": {
              "image": "icon.png",
              "altText": "Devory"
            }
          },
          {
            "id": "devory.step.runFactory",
            "title": "Run the factory",
            "description": "Start the AI agent loop. It picks up tasks from ``tasks/ready/`` and executes them.\n\n[Start Factory Run](command:devory.runStart)",
            "media": {
              "image": "icon.png",
              "altText": "Devory"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --platform=node --format=cjs",
    "prepackage": "npm run build",
    "package": "vsce package --no-dependencies --allow-missing-repository && npx tsx ../../scripts/validate-vsix-runtime.ts",
    "test": "tsx --test src/test/task-reader.test.ts src/test/run-reader.test.ts src/test/show-work-reader.test.ts src/test/cli-bridge.test.ts src/test/task-create.test.ts src/test/task-move.test.ts src/test/task-control.test.ts src/test/control-command-flow.test.ts src/test/post-commit-handoff.test.ts src/test/contributions.test.ts src/test/capabilities.test.ts src/test/governance-status.test.ts src/test/run-adapter.test.ts src/test/run-controller.test.ts src/test/seed-starter.test.ts src/test/find-devory-cli.test.ts src/test/init-workspace.test.ts src/test/bootstrap.test.ts src/test/factory-content.test.ts src/test/stored-data.test.ts"
  },
  "dependencies": {
    "@devory/cli": "*",
    "@devory/core": "*"
  },
  "devDependencies": {
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "sinon": "^21.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
